# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687      # neo4j+s://xxxx.databases.neo4j.io em produção
NEO4J_USER=neo4j
NEO4J_PASSWORD=senha_forte_aqui      # Mínimo 8 caracteres
NEO4J_DATABASE=neo4j

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                  # gemini | openai | ollama
GEMINI_API_KEY=sua_chave_aqui
# OPENAI_API_KEY=sua_chave_aqui      # se usar openai

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production               # production desabilita /docs e /redoc
FRONTEND_URL=http://localhost:3000   # CSV de origens CORS permitidas (ex: https://tia.org,https://app.tia.org)
RATE_LIMIT_ENABLED=true              # false para desabilitar rate limiting em testes
